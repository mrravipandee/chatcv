# ── Database ───────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/?appName=AppName

# ── Auth ───────────────────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key
JWT_EXPIRES=7d

# ── Email ──────────────────────────────────────────────────────────────────────
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# ── CORS ───────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# ── AI (Google Gemini API) ───────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Redis (optional — falls back to MongoDB if not set) ───────────────────────
# Get free Redis: https://upstash.com or https://railway.app
REDIS_URL=redis://localhost:6379

# ── Razorpay Payments ─────────────────────────────────────────────────────────
# Sign up at https://razorpay.com — free account, no approval needed for test
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5001
NODE_ENV=development
